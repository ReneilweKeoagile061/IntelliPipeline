# Local-first (Path B — build offline first)
INTELLIPIPELINE_LOCAL=1
FEATURE_STORE_PATH=data/fraud_features.csv
MLFLOW_TRACKING_URI=file:./mlruns
INTELLIPIPELINE_ROOT=

# Azure (Week 6+ — optional until demo)
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-intellipipeline
AZURE_ML_WORKSPACE=mlw-intellipipeline
AZURE_STORAGE_CONNECTION_STRING=get-from-azure-portal
AZURE_ML_ENDPOINT_URL=https://intellipipeline-endpoint.southafricanorth.inference.ml.azure.com/score
AZURE_ML_ENDPOINT_KEY=get-from-azure-ml-studio

# Claude API
ANTHROPIC_API_KEY=your-claude-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Airflow
AIRFLOW_API_URL=http://intellipipeline-airflow/api/v1
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=your-airflow-password

# Feature Store
FEATURE_STORE_PATH=data/fraud_features.parquet
STORAGE_ACCOUNT=stintellipipeline
MLFLOW_TRACKING_URI=file:./mlruns

# API
API_PORT=5000
CORS_ORIGINS=http://localhost:5173

# Frontend
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_NAME=IntelliPipeline
